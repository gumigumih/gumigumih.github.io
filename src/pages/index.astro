---
import '../styles/tailwind.css'
import SiteHead from '../components/SiteHead.astro'
import AnimatedBackground from '../components/AnimatedBackground.astro'
import SiteHeader from '../components/SiteHeader.astro'
import HeroSection from '../components/HeroSection.astro'
import IntroSection from '../components/IntroSection.astro'
import ToolsSection from '../components/ToolsSection.astro'
import WorksSection from '../components/WorksSection.astro'
import ContactSection from '../components/ContactSection.astro'
import SiteFooter from '../components/SiteFooter.astro'
import revealOnScrollSrc from '../scripts/revealOnScroll.ts?url'
---
<!DOCTYPE html>
<html lang="ja">

<head>
  <SiteHead
    title="meg+gumi | Webアプリを中心にしたポートフォリオ"
    description="実際に使えるWebアプリを中心に、制作物や活動をまとめた個人サイトです。"
    canonicalPath="/"
  />
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>

<body class="relative isolate bg-gradient-to-br from-slate-50 to-slate-100" id="app">
  <AnimatedBackground />
  <div class="relative z-10">
    <SiteHeader />
    <HeroSection />
    <ToolsSection />
    <WorksSection />
    <IntroSection />
    <ContactSection />
    <SiteFooter />
  </div>
  <script type="module" src={revealOnScrollSrc}></script>
</body>

</html>

<style is:global>
  .reveal-ready [data-reveal],
  .reveal-ready [data-reveal-item] {
    opacity: 0;
    transform:
      translate3d(var(--reveal-x, 0), var(--reveal-y, 28px), 0)
      rotate(var(--reveal-rotate, 0deg))
      scale(var(--reveal-scale, 1));
    filter: blur(12px);
    transition:
      opacity 780ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 900ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform, filter;
  }

  .reveal-ready [data-reveal="eyebrow"] {
    --reveal-x: -14px;
    --reveal-y: 0;
  }

  .reveal-ready [data-reveal="title"] {
    --reveal-y: 34px;
    --reveal-scale: 0.97;
  }

  .reveal-ready [data-reveal="lead"] {
    --reveal-y: 20px;
  }

  .reveal-ready [data-reveal-item] {
    --reveal-y: 38px;
    --reveal-scale: 0.975;
    --reveal-rotate: -1.2deg;
  }

  .reveal-ready [data-reveal-item]:nth-child(even) {
    --reveal-rotate: 1.2deg;
  }

  .reveal-ready .is-revealed {
    opacity: 1;
    transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    filter: blur(0);
  }

  .reveal-ready [data-reveal="eyebrow"] > span:first-child {
    transform-origin: left center;
    transform: scaleX(0.15);
    transition: transform 760ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--reveal-delay, 0ms) + 120ms);
  }

  .reveal-ready [data-reveal="eyebrow"].is-revealed > span:first-child {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-ready [data-reveal],
    .reveal-ready [data-reveal-item] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .reveal-ready [data-reveal="eyebrow"] > span:first-child {
      transform: none;
      transition: none;
    }
  }
</style>
