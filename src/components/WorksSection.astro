---
import 'swiper/css/bundle'
import SectionFrame from './SectionFrame.astro'
import genreSliderSrc from '../scripts/genreSliders.ts?url'

const selectedProjects = [
  {
    title: 'わりまる / わけたべ',
    role: 'Side Project',
    description: '飲み会や旅行の割り勘を軽くするために作った、暮らし寄りのWebアプリです。',
    image: '/assets/images/warimaru/ogp.png',
    href: '/works/warimaru',
    period: '2025.06',
    external: false,
  },
  {
    title: 'React電卓入力フォーム',
    role: 'npm Package',
    description: '思いついてから8時間で公開した、React用の電卓付き入力フォームです。',
    image: '/assets/images/articles/note_125488845_1776397303577.jpg',
    href: '/works/react-calculator-input-form',
    period: '2025.09',
    external: false,
  },
  {
    title: 'このポートフォリオ',
    role: 'Personal Site',
    description: '個人の制作物や活動を、外から見やすくまとめたポートフォリオです。',
    image: '/assets/images/profile.jpg',
    href: '#top',
    period: '2026.04',
    external: false,
  },
]
---

<SectionFrame
  id="works"
  eyebrow="project"
  title="つくったもの"
  bgClass="bg-transparent"
  eyebrowClass="text-slate-500"
  titleClass="text-slate-900"
  leadClass="text-slate-600"
  lead="つくってきたものを、並べて見られるようにしています。"
>
  <div class="relative" data-genre-slider-root>
    <div class="swiper overflow-visible slider-edge-mask" data-genre-slider>
      <div class="swiper-wrapper">
        {selectedProjects.map((item) => (
          <div class="swiper-slide h-auto">
            <a
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
              class="group flex flex-col h-full bg-white rounded-2xl overflow-hidden ring-1 ring-slate-200 hover:ring-slate-300 transition transform hover:-translate-y-1 shadow-md shadow-slate-200/50 hover:shadow-lg"
            >
              <div class="relative aspect-[16/9] overflow-hidden bg-slate-100">
                <img
                  src={item.image}
                  alt={`${item.title} のサムネイル`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover transition duration-300 group-hover:scale-105"
                />
              </div>
              <div class="p-5 md:p-6 flex-1 h-full flex flex-col gap-3 text-slate-900">
                <div class="flex items-center justify-between text-xs text-slate-500">
                  <span class="flex items-center gap-2 uppercase tracking-[0.2em]">
                    <span class="h-0.5 w-5 bg-slate-400 block"></span>
                    {item.role}
                  </span>
                  <span class="text-[11px] text-slate-500 tracking-normal font-semibold">
                    {item.period}
                  </span>
                </div>
                <div class="space-y-2 flex-1">
                  <h4 class="text-xl font-bold leading-tight">{item.title}</h4>
                  <p class="text-sm text-slate-600 leading-relaxed">{item.description}</p>
                </div>
                <div class="flex items-center gap-2 text-slate-600 font-semibold text-sm mt-auto pt-2">
                  <span>{item.external ? '読む' : '詳細を見る'}</span>
                  <i class="fa-solid fa-arrow-right-long transition-transform duration-200 group-hover:translate-x-1"></i>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
    <div class="grid grid-cols-[auto,1fr,auto] items-center gap-3 mt-4">
      <button
        type="button"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200 transition"
        aria-label="前のProjectへ"
        data-genre-prev
      >
        <i class="fa-solid fa-chevron-left"></i>
      </button>
      <div class="flex justify-center items-center w-full" data-genre-pagination></div>
      <button
        type="button"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200 transition"
        aria-label="次のProjectへ"
        data-genre-next
      >
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>
  </div>
  <script type="module" src={genreSliderSrc}></script>
  <style>
    :global(.slider-edge-mask) {
      --slider-edge-mask-width: 32px;
      -webkit-mask-image: linear-gradient(to right, transparent 0, #000 var(--slider-edge-mask-width), #000 calc(100% - var(--slider-edge-mask-width)), transparent 100%);
      mask-image: linear-gradient(to right, transparent 0, #000 var(--slider-edge-mask-width), #000 calc(100% - var(--slider-edge-mask-width)), transparent 100%);
    }
    :global(.genre-bullet) {
      @apply inline-block w-2.5 h-2.5 rounded-full bg-slate-300 mx-1 transition hover:bg-slate-400;
    }
    :global(.genre-bullet.is-active) {
      @apply bg-slate-500 w-3 h-3;
    }
    :global([data-genre-prev].swiper-button-disabled),
    :global([data-genre-next].swiper-button-disabled) {
      @apply opacity-40 cursor-not-allowed hover:bg-slate-100;
    }
  </style>
</SectionFrame>
