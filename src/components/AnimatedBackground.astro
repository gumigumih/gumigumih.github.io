---
const shapeCount = 24
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true" data-animated-background>
  {Array.from({ length: shapeCount }).map((_, index) => (
    <div
      class="bg-shape absolute left-1/2 top-1/2 will-change-transform"
      data-bg-shape
      data-index={index}
    >
      <span class="shape-kind shape-icon" data-kind="code" aria-hidden="true">
        <i class="fa-solid fa-code"></i>
      </span>
      <span class="shape-kind shape-icon" data-kind="pen" aria-hidden="true">
        <i class="fa-solid fa-pen-nib"></i>
      </span>
      <span class="shape-kind shape-icon" data-kind="lightbulb" aria-hidden="true">
        <i class="fa-solid fa-lightbulb"></i>
      </span>
      <span class="shape-kind shape-icon" data-kind="sparkles" aria-hidden="true">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
      </span>
    </div>
  ))}
</div>

<script>
  const bg = document.querySelector('[data-animated-background]')
  const shapes = Array.from(bg?.querySelectorAll('[data-bg-shape]') ?? [])

  const kinds = ['code', 'pen', 'lightbulb', 'sparkles']
  const palettes = [
    { base: '#ec4899', soft: 'rgba(236, 72, 153, 0.18)' },
    { base: '#facc15', soft: 'rgba(250, 204, 21, 0.18)' },
    { base: '#38bdf8', soft: 'rgba(56, 189, 248, 0.18)' },
  ]

  const rand = (min, max) => Math.random() * (max - min) + min
  const shuffle = (items) => {
    const copied = [...items]
    for (let i = copied.length - 1; i > 0; i -= 1) {
      const j = Math.floor(Math.random() * (i + 1))
      ;[copied[i], copied[j]] = [copied[j], copied[i]]
    }
    return copied
  }

  const palettePool = shuffle(
    Array.from({ length: Math.ceil(shapes.length / palettes.length) }, () => palettes)
      .flat()
      .slice(0, shapes.length),
  )

  const placedPoints = []
  const minDistance = 16

  const getPoint = () => {
    for (let attempt = 0; attempt < 24; attempt += 1) {
      const x = rand(0, 100)
      const y = rand(105, 185)
      const isFarEnough = placedPoints.every((point) => {
        const dx = point.x - x
        const dy = point.y - y
        return Math.sqrt((dx * dx) + (dy * dy)) >= minDistance
      })

      if (isFarEnough) {
        placedPoints.push({ x, y })
        return { x, y }
      }
    }

    const fallback = { x: rand(0, 100), y: rand(105, 185) }
    placedPoints.push(fallback)
    return fallback
  }

  shapes.forEach((shape) => {
    const kind = kinds[Math.floor(Math.random() * kinds.length)]
    const palette = palettePool.shift() ?? palettes[0]
    const size = rand(42, 66)
    const { x, y } = getPoint()
    const sway = rand(-34, 34)
    const rise = rand(135, 240)
    const rotate = rand(-28, 28)
    const duration = rand(28, 46)
    const delay = rand(-46, 0)
    const opacity = rand(0.16, 0.34)

    shape.dataset.kind = kind
    shape.style.left = `${x}%`
    shape.style.top = `${y}%`
    shape.style.width = `${size}px`
    shape.style.height = `${size}px`
    shape.style.setProperty('--shape-color', palette.base)
    shape.style.setProperty('--shape-soft', palette.soft)
    shape.style.setProperty('--shape-opacity', `${opacity}`)
    shape.style.setProperty('--shape-rotate', `${rotate}deg`)
    shape.style.setProperty('--icon-size', `${size * 0.56}px`)
    shape.style.setProperty('--float-sway', `${sway}px`)
    shape.style.setProperty('--rise-distance', `${rise}vh`)
    shape.style.setProperty('--float-duration', `${duration}s`)
    shape.style.setProperty('--float-delay', `${delay}s`)
  })

  const updateScrollDrift = () => {
    const scrollTop = window.scrollY || window.pageYOffset || 0
    const docHeight = Math.max(
      document.documentElement.scrollHeight,
      document.body.scrollHeight,
      document.documentElement.offsetHeight,
      document.body.offsetHeight,
    )
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0
    const maxScroll = Math.max(docHeight - viewportHeight, 1)
    const progress = Math.min(scrollTop / maxScroll, 1)

    bg?.style.setProperty('--scroll-progress', `${progress}`)
    bg?.style.setProperty('--scroll-offset', `${progress * -180}px`)
  }

  const onScroll = () => {
    window.requestAnimationFrame(updateScrollDrift)
  }

  updateScrollDrift()
  window.addEventListener('scroll', onScroll, { passive: true })
  window.addEventListener('resize', updateScrollDrift)
</script>

<style>
  .bg-shape {
    transform: translate(-50%, calc(-50% + var(--scroll-offset, 0px))) rotate(var(--shape-rotate, 0deg)) translate3d(0, 18vh, 0);
    opacity: 0;
    animation: bg-float var(--float-duration, 36s) ease-in-out var(--float-delay, 0s) infinite;
    color: var(--shape-color, #38bdf8);
  }

  .shape-kind {
    display: none;
    width: 100%;
    height: 100%;
  }

  .bg-shape[data-kind="code"] [data-kind="code"],
  .bg-shape[data-kind="pen"] [data-kind="pen"],
  .bg-shape[data-kind="lightbulb"] [data-kind="lightbulb"],
  .bg-shape[data-kind="sparkles"] [data-kind="sparkles"] {
    display: grid;
  }

  .shape-icon {
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, currentColor 10%, transparent);
    box-shadow: 0 0 0 10px var(--shape-soft, rgba(56, 189, 248, 0.18));
  }

  .shape-icon i {
    font-size: var(--icon-size, 28px);
    line-height: 1;
  }

  @keyframes bg-float {
    0% {
      transform: translate(-50%, calc(-50% + var(--scroll-offset, 0px))) rotate(var(--shape-rotate, 0deg)) translate3d(0, 0, 0);
      opacity: 0;
    }
    14% {
      opacity: var(--shape-opacity, 0.2);
    }
    70% {
      opacity: var(--shape-opacity, 0.2);
    }
    100% {
      transform: translate(-50%, calc(-50% + var(--scroll-offset, 0px))) rotate(calc(var(--shape-rotate, 0deg) + 18deg)) translate3d(var(--float-sway, 20px), calc(var(--rise-distance, 180vh) * -1), 0);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-shape {
      animation: none;
    }
  }
</style>
