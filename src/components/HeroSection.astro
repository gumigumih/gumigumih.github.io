---
---

<section class="min-h-[72svh] flex items-center px-4 relative overflow-hidden" id="top" data-reveal-section>
  <div class="relative z-10 w-full max-w-6xl mx-auto pt-20 pb-16 md:pt-24 md:pb-18">
    <div class="max-w-3xl">
      <p class="text-sm md:text-base uppercase tracking-[0.35em] text-slate-500" data-reveal="eyebrow">
        app showcase
      </p>
      <h1
        class="mt-5 text-5xl md:text-[5.25rem] font-black tracking-tight text-slate-900 leading-[0.95] font-['Zen_Maru_Gothic','M_PLUS_1p',sans-serif]"
        data-reveal="title"
      >
        使えるアプリを<br />
        まとめています
      </h1>
      <p class="mt-6 text-lg md:text-2xl leading-relaxed text-slate-700 max-w-2xl" data-reveal="lead">
        使えるものを、まず使える形で。<br />
        Webアプリやデスクトップ向けツールを並べています。
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3" data-reveal>
        <a
          href="#tools"
          class="inline-flex items-center gap-2 rounded-full bg-slate-900 text-white px-5 py-3 text-sm font-medium hover:-translate-y-0.5 hover:shadow-lg transition">
          アプリを見る
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#works"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white/70 text-slate-700 px-5 py-3 text-sm font-medium hover:-translate-y-0.5 hover:border-slate-400 hover:shadow-lg transition backdrop-blur">
          制作物を見る
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center text-slate-500 scroll-prompt" aria-hidden="true">
    <svg
      class="scroll-prompt-svg"
      width="56"
      height="68"
      viewBox="0 0 28 34"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        class="scroll-prompt-chev scroll-prompt-chev-one"
        d="M7 9L14 16L21 9"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        class="scroll-prompt-chev scroll-prompt-chev-two"
        d="M7 16L14 23L21 16"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        class="scroll-prompt-chev scroll-prompt-chev-three"
        d="M7 23L14 30L21 23"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>
</section>

<style>
  .scroll-prompt {
    animation: scroll-prompt-fade 2.8s ease-in-out infinite;
  }

  @keyframes scroll-prompt-fade {
    0%, 100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }

  .scroll-prompt-svg {
    overflow: visible;
  }

  .scroll-prompt-chev {
    animation: scroll-prompt-chevron 2.8s ease-in-out infinite;
  }

  .scroll-prompt-chev-one {
    color: rgba(148, 163, 184, 0.95);
    animation-delay: 0s;
  }

  .scroll-prompt-chev-two {
    color: rgba(59, 130, 246, 0.9);
    animation-delay: 0.12s;
  }

  .scroll-prompt-chev-three {
    color: rgba(236, 72, 153, 0.88);
    animation-delay: 0.24s;
  }

  @keyframes scroll-prompt-chevron {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: translateY(5px);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-prompt,
    .scroll-prompt-chev {
      animation: none;
    }
  }
</style>
