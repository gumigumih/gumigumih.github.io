---
---

<section class="min-h-screen flex items-center px-4 relative overflow-hidden" id="top">
  <div class="relative z-10 w-full max-w-6xl mx-auto pt-24 pb-20">
    <div class="grid gap-10 lg:grid-cols-[1.15fr,0.85fr] items-center">
      <div>
        <p class="text-sm md:text-base uppercase tracking-[0.35em] text-slate-500">
          personal portfolio
        </p>
        <h1 class="mt-5 text-6xl md:text-[5.5rem] font-black tracking-tight text-slate-900">
          <span class="inline-block -translate-x-2 md:-translate-x-4" style="font-family: 'Zen Maru Gothic', 'M PLUS 1p', sans-serif;">
            ぐみ
          </span>
        </h1>
        <p class="mt-6 text-xl md:text-2xl leading-relaxed text-slate-700 max-w-2xl">
          つくる・書く・試す。<br />
          趣味と活動をゆるくまとめた、個人のポートフォリオです。
        </p>
        <p class="mt-5 text-sm md:text-base leading-relaxed text-slate-500 max-w-xl">
          個人開発、文章、UIの微調整、気になったことの実験。
          そんな断片を、そのまま置いています。
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href="#works"
            class="inline-flex items-center gap-2 rounded-full bg-slate-900 text-white px-5 py-3 text-sm font-medium hover:-translate-y-0.5 hover:shadow-lg transition">
            PROJECT
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="#articles"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white/70 text-slate-700 px-5 py-3 text-sm font-medium hover:-translate-y-0.5 hover:border-slate-400 hover:shadow-lg transition backdrop-blur">
            ARTICLES
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white/75 p-5 md:p-6 shadow-xl backdrop-blur-sm">
        <div class="rounded-[1.5rem] overflow-hidden bg-slate-100 ring-1 ring-slate-200">
          <img
            src="/assets/images/profile.jpg"
            alt="meg+gumiのプロフィール写真"
            class="w-full aspect-[4/5] object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <p class="text-xs uppercase tracking-[0.25em] text-slate-400">likes</p>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">
              個人開発 / 文章 / 余白のあるUI
            </p>
          </div>
          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <p class="text-xs uppercase tracking-[0.25em] text-slate-400">mood</p>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">
              思いついたら、まず小さく形にする
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center text-slate-500 scroll-prompt" aria-hidden="true">
    <svg
      class="scroll-prompt-svg"
      width="56"
      height="68"
      viewBox="0 0 28 34"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        class="scroll-prompt-chev scroll-prompt-chev-one"
        d="M7 9L14 16L21 9"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        class="scroll-prompt-chev scroll-prompt-chev-two"
        d="M7 16L14 23L21 16"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        class="scroll-prompt-chev scroll-prompt-chev-three"
        d="M7 23L14 30L21 23"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>
</section>

<style>
  .scroll-prompt {
    animation: scroll-prompt-fade 2.8s ease-in-out infinite;
  }

  @keyframes scroll-prompt-fade {
    0%, 100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }

  .scroll-prompt-svg {
    overflow: visible;
  }

  .scroll-prompt-chev {
    animation: scroll-prompt-chevron 2.8s ease-in-out infinite;
  }

  .scroll-prompt-chev-one {
    color: rgba(148, 163, 184, 0.95);
    animation-delay: 0s;
  }

  .scroll-prompt-chev-two {
    color: rgba(59, 130, 246, 0.9);
    animation-delay: 0.12s;
  }

  .scroll-prompt-chev-three {
    color: rgba(236, 72, 153, 0.88);
    animation-delay: 0.24s;
  }

  @keyframes scroll-prompt-chevron {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: translateY(5px);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-prompt,
    .scroll-prompt-chev {
      animation: none;
    }
  }
</style>
