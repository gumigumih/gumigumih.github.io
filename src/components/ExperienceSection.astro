---
import SectionFrame from './SectionFrame.astro'

const interests = [
  {
    title: 'BUILD',
    heading: '個人開発',
    description: '思いついたものを小さく作って、使いながら育てるのが好きです。',
    rotation: '-rotate-2',
  },
  {
    title: 'WRITE',
    heading: '文章を書く',
    description: '考えたことを note やメモに残して、あとから見返せる形にします。',
    rotation: 'rotate-1',
  },
  {
    title: 'TRY',
    heading: 'AIを試す',
    description: '創作を進めるために、下書きや整理で AI を試しています。',
    rotation: '-rotate-1',
  },
  {
    title: 'DRAW',
    heading: 'お絵描き',
    description: '気が向いたときにラフを描いて、線や色の雰囲気を試します。',
    rotation: 'rotate-2',
  },
  {
    title: 'WALK',
    heading: '写真散歩',
    description: '歩きながら、視点の切り取りが面白い瞬間を探しています。',
    rotation: '-rotate-1',
  },
  {
    title: 'FOOD',
    heading: 'ラーメン巡り',
    description: 'おいしい一杯を探して、ラーメンや中華のお店を少しずつ開拓しています。',
    rotation: 'rotate-1',
  },
]
---

<SectionFrame
  id="experience"
  eyebrow="likes"
  title="好きなこと"
  bgClass="bg-transparent overflow-x-hidden"
  eyebrowClass="text-slate-500 [&+span]:bg-slate-400"
  titleClass="text-slate-900"
  leadClass="text-slate-600"
  lead="日常的に触っているテーマを、カードで並べています。"
>
  <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
    {interests.map((interest) => (
      <article
        class={`group relative rounded-[2rem] bg-white text-slate-900 p-5 md:p-6 ring-1 ring-slate-200 shadow-md shadow-slate-200/50 transition duration-300 hover:-translate-y-1 hover:rotate-0 ${interest.rotation}`}
      >
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-slate-400">{interest.title}</p>
          <h3 class="mt-3 text-xl md:text-2xl font-black leading-tight text-slate-900">{interest.heading}</h3>
        </div>

        <p class="mt-4 text-sm md:text-base text-slate-600 leading-relaxed">
          {interest.description}
        </p>
      </article>
    ))}
  </div>
</SectionFrame>
