---
import SectionFrame from './SectionFrame.astro'

const tools = [
  {
    title: 'わりまる / わけたべ',
    label: '割り勘ツール',
    description: '旅行や食事の支払いを、参加者や食べたものに合わせて整理できるWebツールです。',
    image: '/assets/images/warimaru/ogp.png',
    href: '/warimaru/',
    detailHref: '/works/warimaru',
  },
]
---

<SectionFrame
  id="tools"
  eyebrow="tools"
  title="運営ツール"
  bgClass="bg-white/70"
  eyebrowClass="text-slate-500"
  titleClass="text-slate-900"
  leadClass="text-slate-600"
  lead="サイト内で使えるWebツールをまとめています。"
  bodyWidthClass="max-w-6xl"
>
  <div class="grid grid-cols-1 gap-5 md:gap-6">
    {tools.map((tool) => (
      <article class="grid overflow-hidden rounded-2xl bg-white ring-1 ring-slate-200 shadow-md shadow-slate-200/50 md:grid-cols-[minmax(260px,0.9fr)_minmax(0,1.1fr)]">
        <a href={tool.href} class="group block bg-slate-100">
          <img
            src={tool.image}
            alt={`${tool.title} のスクリーンショット`}
            loading="lazy"
            decoding="async"
            class="h-full min-h-56 w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </a>
        <div class="flex flex-col gap-5 p-5 text-slate-900 md:p-7">
          <div class="space-y-3">
            <div class="flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-slate-500">
              <span class="h-0.5 w-5 bg-slate-400"></span>
              {tool.label}
            </div>
            <h3 class="text-2xl font-black leading-tight">{tool.title}</h3>
            <p class="max-w-2xl text-sm leading-relaxed text-slate-600 md:text-base">{tool.description}</p>
          </div>
          <div class="mt-auto flex flex-wrap gap-3">
            <a
              href={tool.href}
              class="inline-flex items-center gap-2 rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-slate-800"
            >
              <span>ツールを開く</span>
              <i class="fa-solid fa-arrow-right-long"></i>
            </a>
            <a
              href={tool.detailHref}
              class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50"
            >
              <span>制作背景を見る</span>
              <i class="fa-solid fa-book-open"></i>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</SectionFrame>
